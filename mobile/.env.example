# Web browser execution can use localhost because the browser runs on the PC.
EXPO_PUBLIC_WEB_API_BASE_URL=http://localhost:8080/api/v1

# Expo Go on a physical phone cannot use localhost for the PC backend.
# The app usually derives this from the Expo dev server host automatically.
# If it does not, uncomment this and replace the IP with your PC's Wi-Fi/LAN IPv4 address.
# EXPO_PUBLIC_MOBILE_API_BASE_URL=http://192.168.0.10:8080/api/v1

# Backend port used when deriving the Expo Go API URL from the dev server host.
EXPO_PUBLIC_API_PORT=8080

# Legacy fallback. Native app builds ignore this when it points at localhost.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

EXPO_PUBLIC_CHAIN_RPC_URL=http://localhost:8545
EXPO_PUBLIC_CHAIN_ID=31337
EXPO_PUBLIC_TRUST_TICKET_CONTRACT_ADDRESS=
