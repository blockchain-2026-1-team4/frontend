# Web browser execution can use localhost because the browser runs on the PC.
EXPO_PUBLIC_WEB_API_BASE_URL=http://localhost:8080/api/v1

# Expo Go on a physical phone cannot use localhost for the PC backend.
# The app usually derives this from the Expo dev server host automatically.
# If it does not, uncomment this and replace the IP with your PC's Wi-Fi/LAN IPv4 address.
# EXPO_PUBLIC_MOBILE_API_BASE_URL=http://192.168.0.10:8080/api/v1

# Backend port used when deriving the Expo Go API URL from the dev server host.
EXPO_PUBLIC_API_PORT=8080

# Legacy fallback. Native app builds ignore this when it points at localhost.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# WalletConnect metadata shown in MetaMask connection requests.
# DAPP_URL is informational only (not verified at runtime). Set to the production
# HTTPS URL when deployed; a placeholder is acceptable during development.
EXPO_PUBLIC_DAPP_NAME=Trust Ticket
EXPO_PUBLIC_DAPP_URL=https://your-production-domain.com
EXPO_PUBLIC_APP_SCHEME=trustticket

# Reown (WalletConnect) project ID — create one at https://dashboard.reown.com/
EXPO_PUBLIC_REOWN_PROJECT_ID=YOUR_REOWN_PROJECT_ID

# Kaia Kairos testnet (Chain ID 1001).
#
# WHY KAIROS, NOT HARDHAT 31337:
#   WalletConnect sessions and MetaMask transactions must run against the same
#   public EVM chain as the deployed contracts. This project uses Kairos.
#   personal_sign for nonce-based login is chain-agnostic — the same wallet address
#   is used on every EVM chain.
#
# WHY PUBLIC RPC, NOT localhost:8545:
#   A physical phone cannot reach localhost on the development PC. Always use a
#   network-reachable RPC URL when testing on a real device.
EXPO_PUBLIC_CHAIN_RPC_URL=https://public-en-kairos.node.kaia.io
EXPO_PUBLIC_CHAIN_ID=1001

# TrustTicket smart contract address on Kaia Kairos (format: 0x + 40 hex chars).
EXPO_PUBLIC_TRUST_TICKET_CONTRACT_ADDRESS=0x3e1B4b3F8B61D12DFe7Ba1d8893Ff4E84bdb378C
EXPO_PUBLIC_FANCLUB_MEMBERSHIP_CONTRACT_ADDRESS=0x73aF7a3B647a81ab7003817c9Cb99137fF6A6b4D
